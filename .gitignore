# Python
__pycache__/
*.py[cod]
.pytest_cache/
.tmp/

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env

# Logs
logs/sessions/
*.log

# Generated indexes
data/index/

# Local runtime state
data/project_state/tasks.json
data/project_state/journal.jsonl
data/workflows/active/*.json
data/workflows/history/*.json
!data/workflows/active/.gitkeep
!data/workflows/history/.gitkeep

# Local Patch Tools state and backups
data/patches/

# Local Project Memory
data/memory/*
!data/memory/.gitkeep
# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Check logs
logs/checks/

# Backup files
*.bak*
scripts/*.bak*

# Archived local task snapshots
data/tasks/archive/

# Local model profile state
data/model_profile.json

# Keep user documents out of git by default
data/documents/*
!data/documents/example.md
!data/documents/smoke_test.md
!data/documents/vega_v031_test.md

# Extra Python artifacts
.Python
.env.local
logs/terminal/

# Opt-in bounded execution diagnostics
logs/diagnostics/execution-traces.jsonl
logs/diagnostics/execution-traces.jsonl.*
logs/diagnostics/reports/
logs/diagnostics/quarantine/
logs/diagnostics/.*.lock
logs/diagnostics/*.tmp

# Runtime web audit logs
logs/web/*.jsonl

data/checkpoints/
