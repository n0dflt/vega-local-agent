{
  "schema_version": 1,
  "default_timeout_seconds": 60,
  "max_output_chars": 50000,
  "commands": [
    {
      "id": "python-version",
      "description": "Show the active Python version.",
      "argv": [
        "python",
        "--version"
      ],
      "timeout_seconds": 10,
      "enabled": true
    },
    {
      "id": "compile",
      "description": "Compile VEGA Python modules.",
      "argv": [
        "python",
        "-m",
        "compileall",
        "core",
        "tools",
        "permissions",
        "plugins",
        "domains",
        "workflows",
        "planner",
        "memory",
        "rag",
        "review",
        "scripts",
        "tests",
        "ui",
        "web_demo"
      ],
      "timeout_seconds": 120,
      "enabled": true
    },
    {
      "id": "tests",
      "description": "Run all VEGA tests with pytest.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "-rs",
        "-p",
        "no:cacheprovider",
        "--basetemp",
        ".tmp/pytest-release",
        "--tb=short"
      ],
      "timeout_seconds": 180,
      "enabled": true
    },
    {
      "id": "tests-terminal",
      "description": "Run all Terminal Tools tests.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "--tb=short",
        "tests/test_terminal_tools.py",
        "tests/test_terminal_commands.py"
      ],
      "timeout_seconds": 180,
      "enabled": true
    },
    {
      "id": "tests-workflow",
      "description": "Run the focused controlled-workflow safety suite.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "-rs",
        "-p",
        "no:cacheprovider",
        "--tb=short",
        "tests/test_controlled_workflows.py",
        "tests/test_controlled_workflow_security.py",
        "tests/test_workflow_commands.py"
      ],
      "timeout_seconds": 180,
      "enabled": true
    },
    {
      "id": "tests-terminal-tools",
      "description": "Run Terminal Tools unit tests.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "--tb=short",
        "tests/test_terminal_tools.py"
      ],
      "timeout_seconds": 180,
      "enabled": true
    },
    {
      "id": "tests-terminal-commands",
      "description": "Run Terminal command handler tests.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "--tb=short",
        "tests/test_terminal_commands.py"
      ],
      "timeout_seconds": 180,
      "enabled": true
    },
    {
      "id": "smoke",
      "description": "Run the VEGA smoke test.",
      "argv": [
        "python",
        "scripts/smoke_test.py"
      ],
      "timeout_seconds": 60,
      "enabled": true
    },
    {
      "id": "identity",
      "description": "Run the VEGA identity check.",
      "argv": [
        "python",
        "scripts/check_identity.py"
      ],
      "timeout_seconds": 30,
      "enabled": true
    },
    {
      "id": "policy-consistency",
      "description": "Validate the production cross-layer policy snapshot.",
      "argv": [
        "python",
        "scripts/check_policy_consistency.py"
      ],
      "timeout_seconds": 30,
      "enabled": true
    },
    {
      "id": "repository-hygiene",
      "description": "Validate whitespace and generated-state Git hygiene.",
      "argv": [
        "python",
        "scripts/check_repository_hygiene.py"
      ],
      "timeout_seconds": 30,
      "enabled": true
    },
    {
      "id": "tests-web",
      "description": "Run all Controlled Internet Layer tests.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "--tb=short",
        "tests/test_network_safety.py",
        "tests/test_web_tools.py",
        "tests/test_web_commands.py",
        "tests/test_web_cli.py"
      ],
      "timeout_seconds": 180,
      "enabled": true
    },
    {
      "id": "tests-web-tools",
      "description": "Run web safety and Web Tools unit tests.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "--tb=short",
        "tests/test_network_safety.py",
        "tests/test_web_tools.py"
      ],
      "timeout_seconds": 180,
      "enabled": true
    },
    {
      "id": "tests-web-commands",
      "description": "Run internet and web command handler tests.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "--tb=short",
        "tests/test_web_commands.py"
      ],
      "timeout_seconds": 180,
      "enabled": true
    },
    {
      "id": "tests-web-cli",
      "description": "Run Controlled Internet Layer CLI routing tests.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "--tb=short",
        "tests/test_web_cli.py"
      ],
      "timeout_seconds": 180,
      "enabled": true
    },
    {
      "id": "tests-docs",
      "description": "Run all Documentation Builder tests.",
      "argv": [
        "python",
        "-m",
        "pytest",
        "-q",
        "--tb=short",
        "tests/test_doc_tools.py",
        "tests/test_doc_commands.py",
        "tests/test_doc_cli.py",
        "tests/test_doc_builders.py"
      ],
      "timeout_seconds": 180,
      "enabled": true
    }
  ]
}
